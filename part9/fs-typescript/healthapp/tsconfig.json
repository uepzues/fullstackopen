{
  "compilerOptions": {
    "target": "esnext",
    "noEmit": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "module": "nodenext",
    "esModuleInterop": true,
    "allowImportingTsExtensions": false,
    "outDir": "dist/",
    "types": ["node"]
  },
  "include": ["./**/*"]
}
